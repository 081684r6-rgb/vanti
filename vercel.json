{
  "version": 2,
  "builds": [
    { "src": "**/*.php", "use": "@vercel/php" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/((?!.*\\.).*)$", "dest": "/$1.php" },
    { "src": "^/((?!.*\\.).*)$", "dest": "/$1.html" }
  ]
}
